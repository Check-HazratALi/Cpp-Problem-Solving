#include <iostream>
using namespace std;

int main() {
    int n, temp, reverse = 0;

    cin >> n;

    temp = n;

    while (temp != 0) {
        int digit = temp % 10;
        reverse = reverse * 10 + digit;
        temp = temp / 10;
    }

    if (n == reverse)
        cout << "Palindrome Number";
    else
        cout<<"Not Palindrome Number";

    return 0;
}